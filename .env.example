# ═══════════════════════════════════════════════════════════
#  V2VEC 环境配置模板
#  复制此文件为 .env 并填入实际值
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── 阿里云 DashScope ASR API（必填）────────────────────
# 在控制台获取：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API 端点（国内站默认，国际站用 dashscope-intl.aliyuncs.com）
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation

# 模型名称（qwen3-asr-flash：≤5min / qwen3-asr-flash-filetrans：≤12h）
# ASR_MODEL=qwen3-asr-flash

# 默认转录语言
# ASR_LANGUAGE=Chinese

# ── Q&A 提取 LLM（可选，不填则使用启发式规则）─────────
# QA_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# QA_LLM_BASE_URL=https://api.openai.com/v1
# QA_LLM_MODEL=gpt-4o-mini

# ── 服务端口（可选）────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
